ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-opus-4-6

# -----------------------------------------------------------------------
# SERP / Competitor Research Agent — provider configuration
# -----------------------------------------------------------------------
# SERP_PROVIDER controls which SERP backend the SERP Research Agent uses.
#
# mock    (default) — no live internet required; agent generates a
#                     clearly-labeled category-pattern stub.
# serpapi            — live Google results via SerpAPI (serpapi.com).
#                     Requires SERPAPI_KEY to be set.
#
# Default is mock so the agent runs out of the box without any API keys.
# -----------------------------------------------------------------------
SERP_PROVIDER=mock

# Required only when SERP_PROVIDER=serpapi
# SERPAPI_KEY=your-serpapi-key-here

# Set to true to fetch and include page body text in live SERP mode.
# Increases analysis quality but also API/network usage.
# SERP_FETCH_PAGES=false
